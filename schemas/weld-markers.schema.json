{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zhaohaoran-suanhai.github.io/hypermesh-weld-agent/weld-markers.schema.json",
  "$defs": {
    "vector3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        {"type": "number"},
        {"type": "number"},
        {"type": "number"}
      ],
      "items": false
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["marker_count", "cylinder_marker", "triangular_marker", "unknown_marker"],
      "properties": {
        "marker_count": {"type": "integer", "minimum": 0},
        "cylinder_marker": {"type": "integer", "minimum": 0},
        "triangular_marker": {"type": "integer", "minimum": 0},
        "unknown_marker": {"type": "integer", "minimum": 0}
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "status",
    "input",
    "algorithm",
    "hypermesh",
    "summary",
    "components",
    "markers",
    "warnings",
    "elapsed_ms"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"},
    "status": {"const": "success"},
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_path", "manifest_sha256"],
      "properties": {
        "manifest_path": {"type": "string", "minLength": 1},
        "manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "algorithm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "occ_version"],
      "properties": {
        "name": {"const": "explicit-solid-marker-identification"},
        "version": {"type": "string", "minLength": 1},
        "occ_version": {"type": "string", "minLength": 1}
      }
    },
    "hypermesh": {
      "type": "object",
      "additionalProperties": false,
      "required": ["build", "model_name", "units", "coordinate_system"],
      "properties": {
        "build": {"type": "string", "minLength": 1},
        "model_name": {"type": "string", "minLength": 1},
        "units": {"const": "mm"},
        "coordinate_system": {"const": "global"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component_count", "marker_count", "cylinder_marker", "triangular_marker", "unknown_marker"],
      "properties": {
        "component_count": {"type": "integer", "minimum": 1},
        "marker_count": {"type": "integer", "minimum": 0},
        "cylinder_marker": {"type": "integer", "minimum": 0},
        "triangular_marker": {"type": "integer", "minimum": 0},
        "unknown_marker": {"type": "integer", "minimum": 0}
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "marker_count", "cylinder_marker", "triangular_marker", "unknown_marker"],
        "properties": {
          "id": {"type": "integer", "minimum": 1},
          "name": {"type": "string", "minLength": 1},
          "marker_count": {"type": "integer", "minimum": 0},
          "cylinder_marker": {"type": "integer", "minimum": 0},
          "triangular_marker": {"type": "integer", "minimum": 0},
          "unknown_marker": {"type": "integer", "minimum": 0}
        }
      }
    },
    "markers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "marker_id",
          "component_id",
          "component_name",
          "solid_index",
          "marker_type",
          "center",
          "axis",
          "bbox",
          "dimensions",
          "volume",
          "evidence",
          "warnings"
        ],
        "properties": {
          "marker_id": {"type": "string", "pattern": "^C[0-9]{6}-S[0-9]{6}$"},
          "component_id": {"type": "integer", "minimum": 1},
          "component_name": {"type": "string", "minLength": 1},
          "solid_index": {"type": "integer", "minimum": 1},
          "marker_type": {"enum": ["cylinder", "triangular_prism", "unknown"]},
          "center": {"$ref": "#/$defs/vector3"},
          "axis": {
            "anyOf": [
              {"$ref": "#/$defs/vector3"},
              {"type": "null"}
            ]
          },
          "bbox": {"$ref": "selection.schema.json#/$defs/bbox"},
          "dimensions": {"$ref": "#/$defs/vector3"},
          "volume": {"type": "number", "minimum": 0},
          "evidence": {
            "type": "object",
            "additionalProperties": false,
            "required": ["face_count", "surface_types", "edge_counts", "rule"],
            "properties": {
              "face_count": {"type": "integer", "minimum": 0},
              "surface_types": {
                "type": "object",
                "additionalProperties": {"type": "integer", "minimum": 0}
              },
              "edge_counts": {
                "type": "array",
                "items": {"type": "integer", "minimum": 0}
              },
              "rule": {"type": "string", "minLength": 1}
            }
          },
          "warnings": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "elapsed_ms": {"type": "integer", "minimum": 0}
  }
}
